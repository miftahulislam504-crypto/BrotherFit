rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null &&
        firestore.get(/databases/(default)/documents/admins/$(request.auth.uid)).data.isAdmin == true;
    }

    // Product images — public read, admin write
    match /products/{allPaths=**} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // Banner images — public read, admin write
    match /banners/{allPaths=**} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // Category / brand images — public read, admin write
    match /categories/{allPaths=**} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // User profile photos — owner read/write
    match /users/{userId}/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
